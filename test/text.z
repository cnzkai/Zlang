// ============================================================
// 智语言（ZLang）验收测试
// 运行方式：编译后直接运行，查看每个测试项的实际值与期望值
// ============================================================

导入 "a_module"

主函数():
    输出("============================================================\n")
    输出("智语言（ZLang）验收测试\n")
    输出("============================================================\n\n")

    // ========== TR-01 数值与运算符 ==========
    输出("【TR-01】数值与运算符\n")

    r = 42
    输出("  整数42 = %d 期望：42\n", r)

    r = -100
    输出("  负整数 = %d 期望：-100\n", r)

    r = 0
    输出("  零 = %d 期望：0\n", r)

    r = 1 + 2
    输出("  1+2 = %d 期望：3\n", r)

    r = 5 - 3
    输出("  5-3 = %d 期望：2\n", r)

    r = 4 * 5
    输出("  4*5 = %d 期望：20\n", r)

    r = 10 / 2
    输出("  10/2 = %d 期望：5\n", r)

    r = 17 % 5
    输出("  17%%5 = %d 期望：2\n", r)

    r = 2 + 3 * 4
    输出("  2+3*4 = %d 期望：14\n", r)

    r = (2 + 3) * 4
    输出("  (2+3)*4 = %d 期望：20\n", r)

    r = 10 + 20 / 5 - 3 * 2 + 8 % 3
    输出("  综合算术 = %d 期望：10\n", r)

    // ========== TR-02 文本 ==========
    输出("【TR-02】文本\n")

    文本甲 = "你好"
    r = 取长度(文本甲)
    输出("  取长度('你好') = %d 期望：6\n", r)

    r = 取长度("智语言")
    输出("  取长度('智语言') = %d 期望：9\n", r)

    r = 取长度("")
    输出("  取长度('') = %d 期望：0\n", r)

    拼接结果 = "你好" + "世界"
    输出("  '你好'+'世界' = '%s' 期望：'你好世界'\n", 拼接结果)

    r = 比较("abc", "abc")
    输出("  比较('abc','abc') = %d 期望：0\n", r)

    r = 比较("abc", "abd")
    输出("  比较('abc','abd') = %d 期望：<0\n", r)

    r = 比较("abd", "abc")
    输出("  比较('abd','abc') = %d 期望：>0\n", r)

	取文本结果 = 取文本("你好智语言!", 0, 3)
    输出("  取文本('你好智语言!',0,3) = '%s' 期望：'你'\n", 取文本结果)
    
    取文本结果 = 取文本("你好智语言!", 6, 15)
    输出("  取文本('你好智语言!',6,15) = '%s' 期望：'智语言'\n", 取文本结果)

    // ========== TR-03 逻辑与运算符 ==========
    输出("【TR-03】逻辑与运算符\n")

    r = 1 == 1
    输出("  1==1 = %d 期望：1\n", r)

    r = 1 != 2
    输出("  1!=2 = %d 期望：1\n", r)

    r = 5 > 3
    输出("  5>3 = %d 期望：1\n", r)

    r = 3 < 5
    输出("  3<5 = %d 期望：1\n", r)

    r = 5 >= 5
    输出("  5>=5 = %d 期望：1\n", r)

    r = 3 <= 5
    输出("  3<=5 = %d 期望：1\n", r)

    r = (真 且 假)
    输出("  真 且 假 = %d 期望：0\n", r)

    r = (真 或 假)
    输出("  真 或 假 = %d 期望：1\n", r)

    r = !假
    输出("  !假 = %d 期望：1\n", r)

    r = !真
    输出("  !真 = %d 期望：0\n", r)

    r = -10
    输出("  -10 = %d 期望：-10\n", r)

    r = -10 + 5
    输出("  -10+5 = %d 期望：-5\n", r)

    // ========== TR-04 变量 ==========
    输出("【TR-04】变量\n")

    变量甲 = 100
    输出("  变量甲 = %d 期望：100\n", 变量甲)

    变量乙 = 200
    r = 变量甲 + 变量乙
    输出("  变量甲+变量乙 = %d 期望：300\n", r)

    变量丙 = 变量甲 + 变量乙
    输出("  变量丙 = %d 期望：300\n", 变量丙)

    重用变量 = 10
    重用变量 = 20
    输出("  重用变量(覆盖后) = %d 期望：20\n", 重用变量)

    // ========== TR-05 空值 ==========
    输出("【TR-05】空值\n")

    文本 未初始化
    未初始化 = 100
    输出("  未初始化赋值 = %d 期望：100\n", 未初始化)

    // ========== TR-06 ==========
    输出("【TR-06】函数\n")

    r = 加法(3, 5)
    输出("  加法(3,5) = %d 期望：8\n", r)

    r = 减法(50, 20)
    输出("  减法(50,20) = %d 期望：30\n", r)

    r = 乘法运算(8, 9)
    输出("  乘法运算(8,9) = %d 期望：72\n", r)

    r = 除法运算(100, 4)
    输出("  除法运算(100,4) = %d 期望：25\n", r)

    r = 取余(17, 5)
    输出("  取余(17,5) = %d 期望：2\n", r)

    r = 加法(加法(1, 2), 乘法运算(3, 4))
    输出("  加法(加法(1,2),乘法运算(3,4)) = %d 期望：15\n", r)

    r = 斐波那契(5)
    输出("  斐波那契(5) = %d 期望：5\n", r)

    r = 斐波那契(10)
    输出("  斐波那契(10) = %d 期望：55\n", r)

    r = 阶乘(5)
    输出("  阶乘(5) = %d 期望：120\n", r)

    r = 阶乘(10)
    输出("  阶乘(10) = %d 期望：3628800\n", r)

    r = 返回数值()
    输出("  返回数值() = %d 期望：42\n", r)

    返回文本结果 = 返回文本(10)
    输出("  返回文本(10) = '%s' 期望：'10'\n", 返回文本结果)

    // ========== TR-07 条件语句 ==========
    输出("【TR-07】条件语句\n")

    条件值 = 100
    条件结果 = 0
    如果 条件值 > 50:
        条件结果 = 1
    输出("  如果(100>50) 条件结果 = %d 期望：1\n", 条件结果)

    条件结果 = 0
    如果 条件值 < 50:
        条件结果 = 1
    否则:
        条件结果 = 2
    输出("  如果(100<50) 否则 条件结果 = %d 期望：2\n", 条件结果)

    条件结果 = 0
    如果 条件值 == 200:
        条件结果 = 1
    否则如果 条件值 == 100:
        条件结果 = 2
    否则如果 条件值 > 0:
        条件结果 = 3
    否则:
        条件结果 = 4
    输出("  否则如果(100==100) 条件结果 = %d 期望：2\n", 条件结果)

    条件结果 = 0
    如果 50 > 0:
        如果 50 > 25:
            如果 50 > 75:
                条件结果 = 1
            否则:
                条件结果 = 2
        否则:
            条件结果 = 3
    输出("  嵌套条件 条件结果 = %d 期望：2\n", 条件结果)

    // ========== TR-08 循环 ==========
    输出("【TR-08】循环\n")

    循环求和 = 0
    计次循环 i = 0 到 5:
        循环求和 = 循环求和 + i
    输出("  计次循环0到4求和 = %d 期望：10\n", 循环求和)

    循环计数 = 0
    条件循环 循环计数 < 3:
        循环计数 = 循环计数 + 1
    输出("  条件循环(<3)次数 = %d 期望：3\n", 循环计数)

    跳出值 = 0
    计次循环 j = 0 到 20:
        如果 j == 5:
            跳出
        跳出值 = j
    输出("  跳出(在5之前) 跳出值 = %d 期望：4\n", 跳出值)
    输出("  [DEBUG] 到达跳过测试前\n")

    跳过求和 = 0
    计次循环 k = 0 到 10:
        如果 k % 2 == 0:
            跳过
        跳过求和 = 跳过求和 + k
    输出("  跳过偶数求和(1+3+5+7+9) = %d 期望：25\n", 跳过求和)

    // ========== TR-09 数组 ==========
    输出("【TR-09】数组\n")

    整数数组 = [10, 20, 30, 40, 50]
    输出("  整数数组[0] = %d 期望：10\n", 整数数组[0])
    输出("  整数数组[2] = %d 期望：30\n", 整数数组[2])
    输出("  整数数组[4] = %d 期望：50\n", 整数数组[4])

    r = 取长度(整数数组)
    输出("  取长度(整数数组) = %d 期望：5\n", r)

    整数数组[0] = 999
    输出("  整数数组[0](修改后) = %d 期望：999\n", 整数数组[0])

    数组求和 = 0
    计次循环 idx = 0 到 5:
        数组求和 = 数组求和 + 整数数组[idx]
    输出("  数组遍历求和 = %d 期望：1139\n", 数组求和)

    追加测试数组 = [1, 2, 3]
    追加(追加测试数组, 4)
    输出("  追加后[3] = %d 期望：4\n", 追加测试数组[3])

    r = 取长度(追加测试数组)
    输出("  追加后长度 = %d 期望：4\n", r)

    二维数组 = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
    输出("  二维数组[0][0] = %d 期望：1\n", 二维数组[0][0])
    输出("  二维数组[1][1] = %d 期望：5\n", 二维数组[1][1])
    输出("  二维数组[2][2] = %d 期望：9\n", 二维数组[2][2])

    参数数组 = [10, 20, 30]
    r = 加法(参数数组[0], 参数数组[1])
    输出("  加法(数组[0],数组[1]) = %d 期望：30\n", r)

    索引值 = 1
    输出("  数组[索引值] = %d 期望：20\n", 参数数组[索引值])
    输出("  数组[索引值+1] = %d 期望：30\n", 参数数组[索引值 + 1])

    // ========== TR-10 内置==========
    输出("【TR-10】内置函数\n")

    r = 转数值("12345")
    输出("  转数值('12345') = %d 期望：12345\n", r)

    转文本结果 = 转文本(42)
    输出("  转文本(42) = '%s' 期望：'42'\n", 转文本结果)

    r = 查找("你好智语言", "智语言")
    输出("  查找('你好智语言','智语言') = %d 期望：6\n", r)

    r = 查找("abc", "xyz")
    输出("  查找('abc','xyz') = %d 期望：<0\n", r)

    内存指针 = 分配(100)
    输出("  分配(100) 指针 = %d 期望：!=0\n", 内存指针)
    释放(内存指针)
    输出("  释放后程序正常\n")

    // ========== TR-11 指针 ==========
    输出("【TR-11】指针\n")

    指针测试变量 = 100
    指针地址 = &指针测试变量
    解引用值 = *指针地址
    输出("  原始值 = %d 期望：100\n", 指针测试变量)
    输出("  &变量地址 != 0\n")
    输出("  *地址解引用 = %d 期望：100\n", 解引用值)

    // 测试中文函数形式
    中文取地址 = 取地址(指针测试变量)
    中文解引用 = 解引用(中文取地址)
    输出("  取地址(变量) != 0 期望：!=0\n")
    输出("  解引用(地址) = %d 期望：100\n", 中文解引用)

    // ========== TR-12 结构体 ==========
    输出("【TR-12】结构体\n")

    //自动创建结构体并识别类型
    点A = {x: 100, y: 200}
    输出("  点A.x = %d 期望：100\n", 点A.x)
    输出("  点A.y = %d 期望：200\n", 点A.y)

    坐标 = {x: 10, y: 20}
    输出("  坐标.x = %d 期望：10\n", 坐标.x)
    输出("  坐标.y = %d 期望：20\n", 坐标.y)

    结构 人物类型 {
        name: 文本
        age: 数值
        city: 文本
    }
    人物 = {name: "悟空", age: 500, city: "比奇省"}
    输出("  人物.name = '%s' 期望：'悟空'\n", 人物.name)
    输出("  人物.age = %d 期望：500\n", 人物.age)
    输出("  人物.city = '%s' 期望：'比奇省'\n", 人物.city)

    人物.age = 501
    人物.city = "花果山"
    输出("  人物.age(修改后) = %d 期望：501\n", 人物.age)
    输出("  人物.city(修改后) = '%s' 期望：'花果山'\n", 人物.city)

    // 新语法格式测试
    结构 CmdArgs {
        input_file: 文本
        output_file: 文本
        verbose: 逻辑
        help: 逻辑
    }
    args = {input_file: "test.z", output_file: "test.exe", verbose: 真, help: 假}
    输出("  CmdArgs.input_file = '%s' 期望：'test.z'\n", args.input_file)
    输出("  CmdArgs.output_file = '%s' 期望：'test.exe'\n", args.output_file)
    输出("  CmdArgs.verbose = %d 期望：1\n", args.verbose)
    输出("  CmdArgs.help = %d 期望：0\n", args.help)

    // ========== TR-13 模块系统 ==========
    // 模块导入在文件顶部已处理
    输出("【TR-13】模块系统\n")

    模块加法结果 = 测试模块.add(3, 5)
    输出("  测试模块.add(3,5) from module = %d 期望：8\n", 模块加法结果)

    同名函数add结果 = 同名函数测试模块.add(3, 5)
    输出("  同名函数测试模块.add(3,5) from module = %d 期望：15\n", 同名函数add结果)
    
    模块乘法结果 = 测试模块.multiply(4, 5)
    输出("  测试模块.multiply(4,5) from module = %d 期望：20\n", 模块乘法结果)

	输出("  非模块内函数() from a_module.z = %s 期望：非模块内函数,可直接调用\n", 非模块内函数())
	
	//模块私有调用 = 测试模块.内部辅助(1)
    //输出("  测试模块.内部辅助(1) from module = %d 期望：错误，无法调用该内部函数\n",模块私有调用)
    // ========== TR-14 类型系统 ==========
    输出("【TR-14】类型系统\n")

    数值变量 = 42
    文本变量 = "你好"
    逻辑变量 = 真
    数组变量 = [1, 2, 3]
    空值变量 = 空

    输出("  取类型(42) = '%s' 期望：'数值'\n", 取类型(数值变量))
    输出("  取类型('你好') = '%s' 期望：'文本'\n", 取类型(文本变量))
    输出("  取类型(真) = '%s' 期望：'逻辑'\n", 取类型(逻辑变量))
    输出("  取类型([1,2,3]) = '%s' 期望：'数组'\n", 取类型(数组变量))
    输出("  取类型(空) = '%s' 期望：'未知' (无显式类型声明)\n", 取类型(空值变量))

    // ========== TR-15 常量测试 ==========
    输出("【TR-15】常量测试\n")

    常量 PI = 3.14159
    常量 最大值 = 1000
    常量 消息 = "Hello, 智语言!"
    
    输出("  常量 PI = %g 期望：3.14159\n", PI)
    输出("  常量 最大值 = %d 期望：1000\n", 最大值)
    输出("  常量 消息 = '%s' 期望：'Hello, 智语言!'\n", 消息)
    
    // 测试常量表达式
    常量 计算值 = 最大值 + 500
    输出("  常量计算值 = %d 期望：1500\n", 计算值)
    
    // 尝试修改常量（应该会编译错误）
    // PI = 3.14  // 取消注释这行应该会报错
    
    输出("  常量功能测试完成\n")

    // ========== TR-16 文件I/O ==========
    输出("【TR-16】文件I/O\n")
    
    输出("  读文件 (二进制):\n")
    文件字节数组 = 读文件("a_input.txt")
    如果 文件字节数组 != 空:
        输出("  读文件获取的数据类型：%s\n",取类型(文件字节数组))
        输出("  文件字节数组已读取长度：%d\n",取长度(文件字节数组))
        输出("  文件字节数组内容：%s\n",文件字节数组)
        输出("  文件字节数组文本内容：%s\n",转文本(文件字节数组))
    否则:
        输出("  ⚠️ 文件读取返回空值(文件可能不存在或无法访问)\n")
        文件字节数组 = [77, 90]

    写结果 = 写文件("a_output.txt", 文件字节数组)
    如果 写结果:
        输出("  文件字节数组写入成功\n")
        文件字节数组 = 读文件("a_output.txt")
        输出("  写文件再次读取测试: '%s' 期望包含'智语言测试'\n", 转文本(文件字节数组))
    否则:
        输出("  ⚠️ 文件写入失败\n")
        
    写文本("a_output_text.txt", "智语言测试")
    读回内容 = 读文本("a_output_text.txt")
    输出("  写文本+读文本: '%s' 期望包含'智语言测试'\n", 读回内容)

    // ========== TR-17 字符串+运算符 ==========
    输出("【TR-17】字符串+运算符\n")

    三段拼接 = "Hello" + " " + "World"
    输出("  'Hello'+' '+'World' = '%s' 期望：'Hello World'\n", 三段拼接)

    中文拼接 = "智" + "语" + "言"
    输出("  '智'+'语'+'言' = '%s' 期望：'智语言'\n", 中文拼接)

    中文拼接 += "测" + "试"
    输出("  中文拼接 += '测'+'试' = '%s' 期望：'智语言测试'\n", 中文拼接)
    
    中文拼接 = "你好，" + 中文拼接
    输出("  '你好，'+中文拼接 = '%s' 期望：'你好，智语言测试'\n", 中文拼接)
    
    数值拼接 = 转文本(42)
    输出("  转文本(42) = '%s' 期望：'42'\n", 数值拼接)

    // ========== TR-19 替换==========
    输出("【TR-19】替换函数\n")

    替换结果1 = 替换("你好世界", "世界", "智语言")
    输出("  替换('你好世界','世界','智语言') = '%s' 期望：'你好智语言'\n", 替换结果1)

    替换结果2 = 替换("abcabc", "ab", "x")
    输出("  替换('abcabc','ab','x') = '%s' 期望：'xcxc'\n", 替换结果2)

    替换结果3 = 替换("hello", "xyz", "abc")
    输出("  替换('hello','xyz','abc') = '%s' 期望：'hello'\n", 替换结果3)

    // ========== TR-20 位运算==========
    输出("【TR-20】位运算函数\n")

    输出("  位与(65280, 4080) = %d 期望：3840\n", 位与(65280, 4080))
    输出("  位或(65280, 4080) = %d 期望：65520\n", 位或(65280, 4080))
    输出("  位异或(65280, 4080) = %d 期望：61680\n", 位异或(65280, 4080))
    输出("  左移(1, 8) = %d 期望：256\n", 左移(1, 8))
    输出("  右移(256, 8) = %d 期望：1\n", 右移(256, 8))

    // ========== TR-22 位运算符 ==========
    输出("【TR-22】位运算符\n")

    r = 255 & 15
    输出("  255 & 15 = %d 期望：15\n", r)

    r = 240 | 15
    输出("  240 | 15 = %d 期望：255\n", r)

    r = 255 ^ 15
    输出("  255 ^ 15 = %d 期望：240\n", r)

    r = ~0
    输出("  ~0 = %d 期望：-1\n", r)

    r = ~0 & 255
    输出("  ~0 & 255 = %d 期望：255\n", r)

    // ========== TR-21 综合测试 ==========
    输出("【TR-21】综合测试\n")

    偶数和 = 0
    计次循环 n = 0 到 10:
        如果 n % 2 == 0:
            偶数和 = 偶数和 + n
    输出("  循环内条件-偶数求和 = %d 期望：20\n", 偶数和)

    r = 1 + 2 + 3 + 4 + 5
    输出("  连续加法 1+2+3+4+5 = %d 期望：15\n", r)

    r = 2 * 3 * 4
    输出("  连续乘法 2*3*4 = %d 期望：24\n", r)

    r = !(真 且 假)
    输出("  !(真 且 假) 德摩根 = %d 期望：1\n", r)

    r = !(假 或 假)
    输出("  !(假 或 假) 德摩根 = %d 期望：1\n", r)

    // ========== 完成 ==========
    输出("\n============================================================\n")
    输出("验收测试完成\n")
    输出("============================================================\n")

    退出(0)

// ============================================================
// 辅助函数
// ============================================================
加法(a, b):
    返回 a + b

减法(a, b):
    返回 a - b

乘法运算(a, b):
    返回 a * b

除法运算(a, b):
    返回 a / b

取余(a, b):
    返回 a % b

斐波那契(n):
    如果 n <= 1:
        返回 n
    返回 斐波那契(n - 1) + 斐波那契(n - 2)

阶乘(n):
    如果 n <= 1:
        返回 1
    返回 n * 阶乘(n - 1)

返回数值():
    返回 42

返回文本(n):
    返回 转文本(n)

返回逻辑():
    返回 真
